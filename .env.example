# ============ LiveKit ============
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_SIP_URI=sip:your-sip-uri.sip.livekit.cloud
SIP_OUTBOUND_TRUNK_ID=ST_your_trunk_id

# ============ AI Pipeline ============
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
# LLM model (gpt-4o-mini is ~3x faster than gpt-4o with same quality for this flow)
LLM_MODEL=gpt-4o-mini
# Deepgram Aura-2 TTS voice (~150ms TTFB vs ~800ms for OpenAI TTS)
# Options: aura-2-thalia-en (warm/young F), aura-2-luna-en (friendly F),
#          aura-2-asteria-en (conversational F), aura-2-stella-en (warm F)
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ============ Call routing ============
# Fallback transfer destination, used when TaskRouter queue is not provisioned or
# /api/transfer/prepare is unreachable. Prospect never sees this number.
TRANSFER_TO_NUMBER=+12025551234

# URL Emma hits before SIP REFER to register routing intent and learn the queue
# number to REFER to. Default works for local dev where dashboard.py runs on :8080.
TRANSFER_QUEUE_URL=http://localhost:8080/api/transfer/prepare

# ============ TaskRouter (agent queueing) ============
# All of these are populated by `python taskrouter_setup.py init` after you set
# TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN + PUBLIC_BASE_URL below.
#
# PUBLIC_BASE_URL must be a public https URL that Twilio can reach. For local
# dev, run ngrok (`ngrok http 8080`) and paste the https URL here. In prod,
# use your actual public dashboard URL.
PUBLIC_BASE_URL=https://your-ngrok-id.ngrok-free.app

# The Twilio phone number that hosts the queue (its Voice webhook must POST to
# {PUBLIC_BASE_URL}/api/transfer/voice). Configure this in the Twilio console
# under Phone Numbers -> Active Numbers -> [number] -> Voice Configuration.
TASKROUTER_QUEUE_NUMBER=+12025550000

# Filled in by `python taskrouter_setup.py init`:
TASKROUTER_WORKSPACE_SID=
TASKROUTER_WORKFLOW_SID=
TASKROUTER_QUEUE_DEFAULT_SID=
TASKROUTER_QUEUE_MANAGER_SID=
TASKROUTER_ACTIVITY_AVAILABLE_SID=
TASKROUTER_ACTIVITY_BUSY_SID=
TASKROUTER_ACTIVITY_WRAPUP_SID=
TASKROUTER_ACTIVITY_LUNCH_SID=
TASKROUTER_ACTIVITY_OFFLINE_SID=

# Seconds an agent stays in Wrap-Up before auto-flipping back to Available.
# Lets the agent enter dispositions / take a breath between calls.
WRAPUP_SECONDS=30
# If an agent's heartbeat is older than this, the reaper flips them to Offline.
HEARTBEAT_STALE_SECONDS=90

# Call-center ambience (mono 48kHz WAV looped under Emma's voice)
CALL_CENTER_AMBIENCE=assets/call_center_bg.wav
AMBIENCE_GAIN=0.04

# ============ Twilio (for trunk setup + landline lookup) ============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1202XXXXXXX

# ============ Phone Scrubbing ============
# Landline detection via Twilio Lookup (~$0.005/lookup)
ENABLE_LANDLINE_CHECK=true
# DNC API (DNCscrub.com, Gryphon, Contact Center Compliance, etc.)
ENABLE_DNC_CHECK=true
DNC_API_KEY=
DNC_API_URL=https://api.dncscrub.com/v1/check
# How many concurrent lookups to run (higher = faster but more API cost)
LOOKUP_CONCURRENCY=10
# Cache TTL for phone lookups (hours) — avoid re-checking the same number
SCRUB_CACHE_TTL_HOURS=168

# ============ ElevenLabs (alternative to LiveKit pipeline) ============
# Used by elevenlabs_dialer.py and elevenlabs_test_call.py
ELEVENLABS_API_KEY=
# Agent ID from ElevenLabs dashboard (Settings -> Agent ID)
ELEVENLABS_AGENT_ID=
# Phone number ID (ElevenLabs dashboard -> Phone Numbers -> click your Twilio number -> ID)
ELEVENLABS_PHONE_NUMBER_ID=
